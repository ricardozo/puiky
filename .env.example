# Puiky — variables de entorno
# Copia este archivo como `.env` y ajusta los valores reales.
# `.env` está en .gitignore: los secretos nunca se versionan.

# --- Postgres ---
POSTGRES_USER=puiky
POSTGRES_PASSWORD=cambia-esta-clave
POSTGRES_DB=puiky
# Host del contenedor de BD visto desde la app (nombre del servicio en docker-compose)
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- API ---
# Puerto en el que se expone FastAPI en la máquina anfitriona
APP_PORT=8000

# --- Embeddings (búsqueda semántica) ---
# Modelo local de sentence-transformers; e5 requiere prefijos "query:"/"passage:"
EMBEDDING_MODEL=intfloat/multilingual-e5-base
# Dimensión del vector: debe coincidir con la columna NOTE.embedding
EMBEDDING_DIM=768
# Backend: "real" (modelo local, producción y prueba de significado real) o
# "fake" (vector determinista sin torch, para tests rápidos / CI).
EMBED_BACKEND=real

# --- NLU / LLM (tool calling) ---
# "real" = endpoint OpenAI-compatible (Ollama con Qwen en el Ubuntu, o vía
# túnel SSH: ssh -L 11434:localhost:11434 usuario@servidor). "fake" = intérprete
# determinista por reglas, para desarrollar sin modelo.
LLM_BACKEND=fake
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=qwen3:14b
LLM_API_KEY=ollama

# --- Transcripción de audio (Whisper) ---
# "real" = faster-whisper (descarga el modelo la primera vez). "fake" = texto fijo.
WHISPER_BACKEND=fake
WHISPER_MODEL=base

# --- Canal Telegram (Fase 3) ---
# Token del bot (de @BotFather). Sin token, el servicio "bot" no arranca.
TELEGRAM_BOT_TOKEN=
# IDs de Telegram autorizados, separados por coma (tu ID lo da @userinfobot,
# o mándale cualquier mensaje al bot y te responderá con tu ID).
TELEGRAM_ALLOWED_IDS=
# URL de la API vista desde el contenedor del bot (red interna de compose).
PUIKY_API_URL=http://app:8000

# --- Zona horaria y scheduler (Fase 4) ---
TIMEZONE=America/Bogota
SCHEDULER_POLL_SECONDS=60
# Insistencia: cada cuántas horas se reitera un recordatorio sin resolver.
REMINDER_REALERT_HOURS=3
# Anticipación escalonada: días antes del vencimiento en que se avisa.
REMINDER_ANTICIPATION_DAYS=3,1,0
# Hora local a la que se disparan los avisos de vencimiento.
REMINDER_HOUR=9
# Umbral de alerta de presupuesto (0.9 = 90% del tope).
BUDGET_ALERT_THRESHOLD=0.9
