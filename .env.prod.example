# Puiky — plantilla de entorno de PRODUCCIÓN (una por instancia).
#
# Cópiala a `.env` en la carpeta de la instancia y ajusta los valores.
# Los secretos se generan con:  openssl rand -hex 32
# `.env` está en .gitignore: nunca se versiona.

# --- Identidad de la instancia (solo informativo / para scripts) ---
INSTANCIA=ricardo

# --- Postgres (aislado por instancia) ---
POSTGRES_USER=puiky
POSTGRES_PASSWORD=GENERA-UNA-CLAVE   # openssl rand -hex 24
POSTGRES_DB=puiky
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Web (nginx) ---
# Puerto en loopback del host al que enruta Cloudflare Tunnel.
# Debe ser ÚNICO por instancia (8080, 8081, 8082, …).
WEB_PORT=8080

# --- Embeddings (búsqueda semántica) ---
EMBEDDING_MODEL=intfloat/multilingual-e5-base
EMBEDDING_DIM=768
EMBED_BACKEND=real

# --- NLU / LLM (Qwen en Ollama del servidor, compartido por todas las instancias) ---
LLM_BACKEND=real
# IP LAN del host donde corre Ollama (alcanzable desde los contenedores).
# Alternativa: http://host.docker.internal:11434/v1 (requiere extra_hosts).
LLM_BASE_URL=http://10.144.82.100:11434/v1
LLM_MODEL=qwen3:14b
LLM_API_KEY=ollama

# --- Transcripción de audio (Whisper) ---
WHISPER_BACKEND=real
WHISPER_MODEL=base

# --- Canal Telegram (PROPIO de cada instancia; nunca compartir el token) ---
TELEGRAM_BOT_TOKEN=   # token de @BotFather de ESTA persona
TELEGRAM_ALLOWED_IDS= # IDs de Telegram autorizados, separados por coma
PUIKY_API_URL=http://app:8000

# --- Zona horaria y scheduler ---
TIMEZONE=America/Bogota
SCHEDULER_POLL_SECONDS=60
REMINDER_REALERT_HOURS=3
REMINDER_ANTICIPATION_DAYS=3,1,0
REMINDER_HOUR=9
BUDGET_ALERT_THRESHOLD=0.9

# --- Autenticación web ---
JWT_SECRET=GENERA-UN-SECRETO      # openssl rand -hex 32
JWT_EXPIRE_MINUTES=10080
SERVICE_TOKEN=GENERA-UN-TOKEN     # openssl rand -hex 32
# Origen público de la instancia (para CORS). Como web y API comparten origen
# vía nginx, normalmente no hace falta, pero se deja por si se llama la API
# desde otro origen. Ej: https://puiky-ricardo.tudominio.com
CORS_ORIGINS=https://puiky-ricardo.tudominio.com
